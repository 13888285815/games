{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:8080/",
        "http://localhost:8080/test-compatibility.html",
        "http://localhost:8080/games/snake.html"
      ],
      "numberOfRuns": 3,
      "settings": {
        "emulatedFormFactor": "mobile",
        "throttlingMethod": "devtools",
        "throttling": {
          "rttMs": 150,
          "throughputKbps": 1638.4,
          "cpuSlowdownMultiplier": 4,
          "requestLatencyMs": 150 * 3.75,
          "downloadThroughputKbps": 1474 * 0.9,
          "uploadThroughputKbps": 675 * 0.9
        }
      },
      "startServerCommand": "npx serve@latest public -p 8080",
      "startServerReadyPattern": "Accepting connections at",
      "startServerReadyTimeout": 10000
    },
    "assert": {
      "preset": "lighthouse:no-pwa",
      "assertions": {
        "categories:performance": ["error", {"minScore": 0.8}],
        "categories:accessibility": ["error", {"minScore": 0.9}],
        "categories:best-practices": ["error", {"minScore": 0.9}],
        "categories:seo": ["error", {"minScore": 0.9}],
        "categories:pwa": ["warn", {"minScore": 0.5}],
        
        "apple-touch-icon": "off",
        "canonical": "off",
        "color-contrast": "warn",
        "crawlable-anchors": "off",
        "document-title": ["error", {"minScore": 0.9}],
        "font-display": "warn",
        "full-page-screenshot": "off",
        "has-robots-txt": ["error", {"minScore": 1}],
        "has-video": "off",
        "heading-order": "warn",
        "image-alt": ["error", {"minScore": 0.9}],
        "image-size-responsive": "warn",
        "installable-manifest": "warn",
        "is-crawlable": "off",
        "largest-contentful-paint": ["error", {"minScore": 0.7}],
        "link-text": "warn",
        "max-potential-fid": ["error", {"maxNumericValue": 130}],
        "meta-description": "warn",
        "meta-refresh": "off",
        "mobile-friendly": ["error", {"minScore": 0.9}],
        "no-document-write": "off",
        "no-unload-listeners": "off",
        "offscreen-images": "warn",
        "plugins": "off",
        "preload-fonts": "warn",
        "render-blocking-resources": ["error", {"minScore": 0.8}],
        "robots-txt": ["error", {"minScore": 1}],
        "service-worker": "warn",
        "splash-screen": "off",
        "tap-targets": ["error", {"minScore": 0.8}],
        "themed-omnibox": "off",
        "third-party-cookies": "off",
        "total-blocking-time": ["error", {"maxNumericValue": 300}],
        "unminified-css": "warn",
        "unminified-javascript": "warn",
        "unsized-images": "warn",
        "valid-source-maps": "off",
        "viewport": ["error", {"minScore": 1}],
        "without-javascript": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage",
      "githubToken": "${{ secrets.GITHUB_TOKEN }}"
    }
  }
}